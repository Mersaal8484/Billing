<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Yemeni Fixed National Holidays (Gregorian)
            These are loaded on module install. To update for future years,
            the HR Manager should create new resource.calendar.leaves records
            via Settings > Technical > Resource > Calendar Leaves.
        -->
        <record id="ye_holiday_labor_day" model="resource.calendar.leaves">
            <field name="name">May Day (Labor Day)</field>
            <field name="date_from">2024-05-01 00:00:00</field>
            <field name="date_to">2024-05-01 23:59:59</field>
            <field name="time_type">leave</field>
        </record>

        <record id="ye_holiday_unity_day" model="resource.calendar.leaves">
            <field name="name">Unity Day (May 22)</field>
            <field name="date_from">2024-05-22 00:00:00</field>
            <field name="date_to">2024-05-22 23:59:59</field>
            <field name="time_type">leave</field>
        </record>

        <record id="ye_holiday_sept_26" model="resource.calendar.leaves">
            <field name="name">September 26 Revolution</field>
            <field name="date_from">2024-09-26 00:00:00</field>
            <field name="date_to">2024-09-26 23:59:59</field>
            <field name="time_type">leave</field>
        </record>

        <record id="ye_holiday_oct_14" model="resource.calendar.leaves">
            <field name="name">October 14 Revolution</field>
            <field name="date_from">2024-10-14 00:00:00</field>
            <field name="date_to">2024-10-14 23:59:59</field>
            <field name="time_type">leave</field>
        </record>

        <record id="ye_holiday_nov_30" model="resource.calendar.leaves">
            <field name="name">Independence Day (Nov 30)</field>
            <field name="date_from">2024-11-30 00:00:00</field>
            <field name="date_to">2024-11-30 23:59:59</field>
            <field name="time_type">leave</field>
        </record>

    </data>
</odoo>
