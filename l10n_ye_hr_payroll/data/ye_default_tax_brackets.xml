<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Default Yemeni Income Tax Brackets (as per current law).
            These are installed once on module install and can be
            modified later via the menu:
            Payroll > Configuration > Yemeni Tax Brackets
        -->
        <record id="ye_bracket_1" model="ye.tax.bracket">
            <field name="name">Exempt (0%)</field>
            <field name="from_amount" eval="0"/>
            <field name="to_amount" eval="10000"/>
            <field name="rate" eval="0"/>
            <field name="fixed_amount" eval="0"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="ye_bracket_2" model="ye.tax.bracket">
            <field name="name">10% Bracket</field>
            <field name="from_amount" eval="10001"/>
            <field name="to_amount" eval="30000"/>
            <field name="rate" eval="10"/>
            <field name="fixed_amount" eval="0"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="ye_bracket_3" model="ye.tax.bracket">
            <field name="name">15% Bracket</field>
            <field name="from_amount" eval="30001"/>
            <field name="to_amount" eval="60000"/>
            <field name="rate" eval="15"/>
            <field name="fixed_amount" eval="2000"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="ye_bracket_4" model="ye.tax.bracket">
            <field name="name">20% Bracket</field>
            <field name="from_amount" eval="60001"/>
            <field name="to_amount" eval="0"/>
            <field name="rate" eval="20"/>
            <field name="fixed_amount" eval="6500"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

    </data>
</odoo>
