<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_session" model="ir.ui.view">
        <field name="name">res.users.form.session</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']" position="after">
                <page string="Sessions" name="sessions">
                    <field name="session_ids" readonly="1">
                        <tree>
                            <field name="name"/>
                            <field name="create_date"/>
                            <field name="last_access"/>
                            <field name="ip_address"/>
                            <field name="is_active"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_users_tree_session" model="ir.ui.view">
        <field name="name">res.users.tree.session</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='login']" position="after">
                <field name="active_session_count" widget="statinfo" string="Active Sessions"/>
            </xpath>
        </field>
    </record>
</odoo>