<!-- views/session_manager_views.xml -->

<odoo>
    <record id="view_session_manager_tree" model="ir.ui.view">
        <field name="name">session.manager.tree</field>
        <field name="model">session.manager</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="user_id"/>
                <field name="db_name"/>
                <field name="login"/>
                <field name="create_date"/>
                <field name="last_access"/>
                <field name="expiry_date"/>
                <field name="ip_address"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <record id="view_session_manager_form" model="ir.ui.view">
        <field name="name">session.manager.form</field>
        <field name="model">session.manager</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id"/>
                        <field name="db_name"/>
                        <field name="login"/>
                        <field name="create_date"/>
                        <field name="last_access"/>
                        <field name="expiry_date"/>
                        <field name="ip_address"/>
                        <field name="user_agent"/>
                        <field name="is_active"/>
                    </group>
                    <group>
                        <field name="session_data" widget="textarea"/>
                    </group>
                </sheet>
                <footer>
                    <button name="force_logout" string="Force Logout" type="object" class="oe_highlight"/>
                    <button name="extend_session" string="Extend 1 Hour" type="object" args="(1)"/>
                </footer>
            </form>
        </field>
    </record>
   <record id="action_session_manager" model="ir.actions.act_window">
        <field name="name">Session Manager</field>
        <field name="res_model">session.manager</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_session_manager_root" name="Sessions"/>
    <menuitem id="menu_session_manager" name="Session Manager" parent="menu_session_manager_root" action="session.action_session_manager"/>


</odoo>