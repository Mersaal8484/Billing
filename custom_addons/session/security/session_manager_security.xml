<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_session_manager" model="res.groups">
        <field name="name">Session Manager</field>
        <field name="category_id" ref="base.module_category_administration"/>
    </record>

    <record id="access_session_manager" model="ir.model.access">
        <field name="name">session.manager.access</field>
