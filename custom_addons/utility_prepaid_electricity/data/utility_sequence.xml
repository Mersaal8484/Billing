<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Customer Sequence -->
        <record id="seq_utility_customer" model="ir.sequence">
            <field name="name">Utility Customer</field>
            <field name="code">utility.customer</field>
            <field name="prefix">CUS/%(year)s/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Account Sequence -->
        <record id="seq_utility_account" model="ir.sequence">
            <field name="name">Utility Account</field>
            <field name="code">utility.account</field>
            <field name="prefix">ACC/%(year)s/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Meter Sequence -->
        <record id="seq_utility_meter" model="ir.sequence">
            <field name="name">Utility Meter</field>
            <field name="code">utility.meter</field>
            <field name="prefix">MTR/</field>
            <field name="padding">8</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sale Sequence -->
        <record id="seq_utility_sale" model="ir.sequence">
            <field name="name">Utility Sale</field>
            <field name="code">utility.sale</field>
            <field name="prefix">SL/%(year)s/</field>
            <field name="padding">8</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Payment Sequence -->
        <record id="seq_utility_payment" model="ir.sequence">
            <field name="name">Utility Payment</field>
            <field name="code">utility.payment</field>
            <field name="prefix">PAY/%(year)s/</field>
            <field name="padding">8</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Transaction Sequence -->
        <record id="seq_utility_transaction" model="ir.sequence">
            <field name="name">Utility Transaction</field>
            <field name="code">utility.transaction</field>
            <field name="prefix">TXN/%(year)s/</field>
            <field name="padding">10</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Adjustment Sequence -->
        <record id="seq_utility_adjustment" model="ir.sequence">
            <field name="name">Utility Adjustment</field>
            <field name="code">utility.adjustment</field>
            <field name="prefix">ADJ/%(year)s/</field>
            <field name="padding">8</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Reversal Sequence -->
        <record id="seq_utility_reversal" model="ir.sequence">
            <field name="name">Utility Reversal</field>
            <field name="code">utility.reversal</field>
            <field name="prefix">REV/%(year)s/</field>
            <field name="padding">8</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Alarm Sequence -->
        <record id="seq_utility_alarm" model="ir.sequence">
            <field name="name">Utility Alarm</field>
            <field name="code">utility.alarm</field>
            <field name="prefix">ALM/%(year)s/</field>
            <field name="padding">8</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Service Order Sequence -->
        <record id="seq_utility_service_order" model="ir.sequence">
            <field name="name">Utility Service Order</field>
            <field name="code">utility.service.order</field>
            <field name="prefix">SO/%(year)s/</field>
            <field name="padding">8</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
