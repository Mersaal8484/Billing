<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Tariff Categories -->
        <record id="tariff_cat_residential" model="utility.tariff.category">
            <field name="name">Residential</field>
            <field name="code">RES</field>
            <field name="sequence">10</field>
        </record>
        <record id="tariff_cat_commercial" model="utility.tariff.category">
            <field name="name">Commercial</field>
            <field name="code">COM</field>
            <field name="sequence">20</field>
        </record>
        <record id="tariff_cat_industrial" model="utility.tariff.category">
            <field name="name">Industrial</field>
            <field name="code">IND</field>
            <field name="sequence">30</field>
        </record>
        <record id="tariff_cat_government" model="utility.tariff.category">
            <field name="name">Government</field>
            <field name="code">GOV</field>
            <field name="sequence">40</field>
        </record>
        <record id="tariff_cat_agriculture" model="utility.tariff.category">
            <field name="name">Agriculture</field>
            <field name="code">AGR</field>
            <field name="sequence">50</field>
        </record>

        <!-- Customer Categories -->
        <record id="cust_cat_individual" model="utility.customer.category">
            <field name="name">Individual</field>
            <field name="code">INDV</field>
            <field name="sequence">10</field>
        </record>
        <record id="cust_cat_company" model="utility.customer.category">
            <field name="name">Company</field>
            <field name="code">COMP</field>
            <field name="sequence">20</field>
        </record>
        <record id="cust_cat_government" model="utility.customer.category">
            <field name="name">Government Entity</field>
            <field name="code">GOVT</field>
            <field name="sequence">30</field>
        </record>

        <!-- Meter Types -->
        <record id="meter_type_single_phase" model="utility.meter.type">
            <field name="name">Single Phase STS</field>
            <field name="code">1P-STS</field>
            <field name="sequence">10</field>
            <field name="phase">single</field>
            <field name="description">Single phase STS prepaid meter</field>
        </record>
        <record id="meter_type_three_phase" model="utility.meter.type">
            <field name="name">Three Phase STS</field>
            <field name="code">3P-STS</field>
            <field name="sequence">20</field>
            <field name="phase">three</field>
            <field name="description">Three phase STS prepaid meter</field>
        </record>
        <record id="meter_type_smart_single" model="utility.meter.type">
            <field name="name">Smart Single Phase</field>
            <field name="code">1P-SMART</field>
            <field name="sequence">30</field>
            <field name="phase">single</field>
            <field name="description">Single phase smart meter with AMI</field>
        </record>
        <record id="meter_type_smart_three" model="utility.meter.type">
            <field name="name">Smart Three Phase</field>
            <field name="code">3P-SMART</field>
            <field name="sequence">40</field>
            <field name="phase">three</field>
            <field name="description">Three phase smart meter with AMI</field>
        </record>

        <!-- Meter Statuses -->
        <record id="meter_status_active" model="utility.meter.status">
            <field name="name">Active</field>
            <field name="code">ACTIVE</field>
            <field name="sequence">10</field>
        </record>
        <record id="meter_status_inactive" model="utility.meter.status">
            <field name="name">Inactive</field>
            <field name="code">INACTIVE</field>
            <field name="sequence">20</field>
        </record>
        <record id="meter_status_fault" model="utility.meter.status">
            <field name="name">Faulty</field>
            <field name="code">FAULT</field>
            <field name="sequence">30</field>
        </record>
        <record id="meter_status_tampered" model="utility.meter.status">
            <field name="name">Tampered</field>
            <field name="code">TAMPERED</field>
            <field name="sequence">40</field>
        </record>
        <record id="meter_status_decommissioned" model="utility.meter.status">
            <field name="name">Decommissioned</field>
            <field name="code">DECOM</field>
            <field name="sequence">50</field>
        </record>

        <!-- Sample Tariffs -->
        <record id="tariff_residential_flat" model="utility.tariff">
            <field name="name">Residential Flat Rate</field>
            <field name="code">RES-FLAT</field>
            <field name="category_id" ref="tariff_cat_residential"/>
            <field name="tariff_type">flat</field>
            <field name="price_per_kwh">0.18</field>
            <field name="fixed_charge">10.00</field>
            <field name="service_charge">5.00</field>
            <field name="tax_percentage">0.15</field>
            <field name="fuel_adjustment">0.02</field>
            <field name="effective_date">2024-01-01</field>
        </record>

        <record id="tariff_commercial_block" model="utility.tariff">
            <field name="name">Commercial Block Rate</field>
            <field name="code">COM-BLOCK</field>
            <field name="category_id" ref="tariff_cat_commercial"/>
            <field name="tariff_type">block</field>
            <field name="fixed_charge">25.00</field>
            <field name="service_charge">15.00</field>
            <field name="tax_percentage">0.15</field>
            <field name="fuel_adjustment">0.03</field>
            <field name="effective_date">2024-01-01</field>
        </record>

        <record id="tariff_commercial_block_1" model="utility.tariff.block">
            <field name="tariff_id" ref="tariff_commercial_block"/>
            <field name="sequence">10</field>
            <field name="name">First 1000 kWh</field>
            <field name="from_kwh">0</field>
            <field name="to_kwh">1000</field>
            <field name="price_per_kwh">0.22</field>
        </record>

        <record id="tariff_commercial_block_2" model="utility.tariff.block">
            <field name="tariff_id" ref="tariff_commercial_block"/>
            <field name="sequence">20</field>
            <field name="name">1001-5000 kWh</field>
            <field name="from_kwh">1001</field>
            <field name="to_kwh">5000</field>
            <field name="price_per_kwh">0.28</field>
        </record>

        <record id="tariff_commercial_block_3" model="utility.tariff.block">
            <field name="tariff_id" ref="tariff_commercial_block"/>
            <field name="sequence">30</field>
            <field name="name">5001+ kWh</field>
            <field name="from_kwh">5001</field>
            <field name="price_per_kwh">0.35</field>
        </record>

        <record id="tariff_industrial_flat" model="utility.tariff">
            <field name="name">Industrial Flat Rate</field>
            <field name="code">IND-FLAT</field>
            <field name="category_id" ref="tariff_cat_industrial"/>
            <field name="tariff_type">flat</field>
            <field name="price_per_kwh">0.12</field>
            <field name="fixed_charge">100.00</field>
            <field name="service_charge">50.00</field>
            <field name="tax_percentage">0.15</field>
            <field name="fuel_adjustment">0.015</field>
            <field name="effective_date">2024-01-01</field>
        </record>

        <record id="tariff_government_flat" model="utility.tariff">
            <field name="name">Government Flat Rate</field>
            <field name="code">GOV-FLAT</field>
            <field name="category_id" ref="tariff_cat_government"/>
            <field name="tariff_type">flat</field>
            <field name="price_per_kwh">0.15</field>
            <field name="fixed_charge">20.00</field>
            <field name="service_charge">10.00</field>
            <field name="tax_percentage">0.0</field>
            <field name="fuel_adjustment">0.02</field>
            <field name="effective_date">2024-01-01</field>
        </record>

        <record id="tariff_agriculture_flat" model="utility.tariff">
            <field name="name">Agriculture Flat Rate</field>
            <field name="code">AGR-FLAT</field>
            <field name="category_id" ref="tariff_cat_agriculture"/>
            <field name="tariff_type">flat</field>
            <field name="price_per_kwh">0.08</field>
            <field name="fixed_charge">0.0</field>
            <field name="service_charge">5.00</field>
            <field name="tax_percentage">0.0</field>
            <field name="fuel_adjustment">0.01</field>
            <field name="effective_date">2024-01-01</field>
        </record>
    </data>
</odoo>
