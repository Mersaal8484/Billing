<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_utility_area_tree" model="ir.ui.view">
        <field name="name">utility.area.tree</field>
        <field name="model">utility.area</field>
        <field name="arch" type="xml">
            <tree string="Service Areas" decoration-danger="not active">
                <field name="code"/>
                <field name="name"/>
                <field name="region_id"/>
                <field name="manager_id"/>
                <field name="customer_count"/>
                <field name="meter_count"/>
            </tree>
        </field>
    </record>

    <record id="view_utility_area_form" model="ir.ui.view">
        <field name="name">utility.area.form</field>
        <field name="model">utility.area</field>
        <field name="arch" type="xml">
            <form string="Service Area">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h2><field name="code"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="region_id"/>
                            <field name="manager_id"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="feeder_count"/>
                            <field name="transformer_count"/>
                            <field name="customer_count"/>
                            <field name="meter_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="feeders" string="Feeders">
                            <field name="feeder_ids">
                                <tree>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="voltage_level"/>
                                    <field name="load_percentage"/>
                                </tree>
                            </field>
                        </page>
                        <page name="transformers" string="Transformers">
                            <field name="transformer_ids">
                                <tree>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="capacity"/>
                                    <field name="load_percentage"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_utility_area_search" model="ir.ui.view">
        <field name="name">utility.area.search</field>
        <field name="model">utility.area</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="region_id"/>
                <field name="manager_id"/>
            </search>
        </field>
    </record>

    <record id="action_utility_area" model="ir.actions.act_window">
        <field name="name">Service Areas</field>
        <field name="res_model">utility.area</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_utility_area_search"/>
    </record>

    <record id="menu_utility_area" model="ir.ui.menu">
        <field name="name">Service Areas</field>
        <field name="parent_id">menu_utility_configuration</field>
        <field name="action" ref="action_utility_area"/>
        <field name="sequence">20</field>
    </record>
</odoo>
