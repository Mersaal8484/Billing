<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_utility_audit_tree" model="ir.ui.view">
        <field name="name">utility.audit.tree</field>
        <field name="model">utility.audit</field>
        <field name="arch" type="xml">
            <tree string="Audit Trail" limit="50">
                <field name="log_date"/>
                <field name="user_id"/>
                <field name="model"/>
                <field name="res_id"/>
                <field name="action"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="view_utility_audit_form" model="ir.ui.view">
        <field name="name">utility.audit.form</field>
        <field name="model">utility.audit</field>
        <field name="arch" type="xml">
            <form string="Audit Entry">
                <group>
                    <group>
                        <field name="log_date"/>
                        <field name="user_id"/>
                        <field name="user_login"/>
                    </group>
                    <group>
                        <field name="model"/>
                        <field name="res_id"/>
                        <field name="action"/>
                    </group>
                </group>
                <field name="description"/>
                <group string="Changes" attrs="{'invisible': [('old_value','=',False)]}">
                    <field name="old_value"/>
                    <field name="new_value"/>
                </group>
            </form>
        </field>
    </record>

    <record id="view_utility_audit_search" model="ir.ui.view">
        <field name="name">utility.audit.search</field>
        <field name="model">utility.audit</field>
        <field name="arch" type="xml">
            <search>
                <field name="model"/>
                <field name="action"/>
                <field name="user_id"/>
                <field name="description"/>
                <filter name="today" string="Today" domain="[('log_date','&gt;=',context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter name="g_model" string="Model" context="{'group_by':'model'}"/>
                    <filter name="g_action" string="Action" context="{'group_by':'action'}"/>
                    <filter name="g_user" string="User" context="{'group_by':'user_id'}"/>
                    <filter name="g_date" string="Date" context="{'group_by':'log_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_utility_audit" model="ir.actions.act_window">
        <field name="name">Audit Trail</field>
        <field name="res_model">utility.audit</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_utility_audit_search"/>
    </record>

    <record id="menu_utility_audit" model="ir.ui.menu">
        <field name="name">Audit Trail</field>
        <field name="parent_id">menu_utility_monitoring</field>
        <field name="action" ref="action_utility_audit"/>
        <field name="sequence">20</field>
    </record>
</odoo>
