<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_utility_customer_category_tree" model="ir.ui.view">
        <field name="name">utility.customer.category.tree</field>
        <field name="model">utility.customer.category</field>
        <field name="arch" type="xml">
            <tree string="Customer Categories">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_utility_customer_tree" model="ir.ui.view">
        <field name="name">utility.customer.tree</field>
        <field name="model">utility.customer</field>
        <field name="arch" type="xml">
            <tree string="Customers" decoration-danger="connection_status not in ('active','')" limit="40">
                <field name="customer_number"/>
                <field name="partner_id"/>
                <field name="national_id"/>
                <field name="mobile"/>
                <field name="customer_type"/>
                <field name="connection_status"/>
                <field name="region_id"/>
                <field name="area_id"/>
                <field name="account_count"/>
            </tree>
        </field>
    </record>

    <record id="view_utility_customer_form" model="ir.ui.view">
        <field name="name">utility.customer.form</field>
        <field name="model">utility.customer</field>
        <field name="arch" type="xml">
            <form string="Customer">
                <header>
                    <field name="connection_status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="customer_number"/></h1>
                        <h2><field name="partner_id"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="national_id"/>
                            <field name="customer_type"/>
                            <field name="category_id"/>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="region_id"/>
                            <field name="area_id"/>
                            <field name="account_count"/>
                            <field name="meter_count"/>
                            <field name="active_account_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="address" string="Address">
                            <group>
                                <group>
                                    <field name="address_street"/>
                                    <field name="address_city"/>
                                    <field name="address_state"/>
                                    <field name="address_zip"/>
                                    <field name="country_id"/>
                                </group>
                                <group>
                                    <field name="gps_latitude"/>
                                    <field name="gps_longitude"/>
                                </group>
                            </group>
                        </page>
                        <page name="accounts" string="Utility Accounts">
                            <field name="account_ids">
                                <tree>
                                    <field name="account_number"/>
                                    <field name="meter_id"/>
                                    <field name="tariff_id"/>
                                    <field name="balance"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page name="documents" string="Documents">
                            <field name="document_ids" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="type"/>
                                    <field name="create_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_utility_customer_search" model="ir.ui.view">
        <field name="name">utility.customer.search</field>
        <field name="model">utility.customer</field>
        <field name="arch" type="xml">
            <search>
                <field name="customer_number"/>
                <field name="partner_id"/>
                <field name="national_id"/>
                <field name="mobile"/>
                <field name="region_id"/>
                <field name="area_id"/>
                <field name="customer_type"/>
                <field name="connection_status"/>
                <filter name="active" string="Active" domain="[('connection_status','=','active')]"/>
                <filter name="disconnected" string="Disconnected" domain="[('connection_status','=','disconnected')]"/>
                <group expand="0" string="Group By">
                    <filter name="g_type" string="Customer Type" context="{'group_by':'customer_type'}"/>
                    <filter name="g_region" string="Region" context="{'group_by':'region_id'}"/>
                    <filter name="g_area" string="Area" context="{'group_by':'area_id'}"/>
                    <filter name="g_status" string="Connection Status" context="{'group_by':'connection_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_utility_customer_pivot" model="ir.ui.view">
        <field name="name">utility.customer.pivot</field>
        <field name="model">utility.customer</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="customer_type" type="row"/>
                <field name="connection_status" type="col"/>
                <field name="account_count" type="value"/>
            </pivot>
        </field>
    </record>

    <record id="action_utility_customer" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">utility.customer</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="search_view_id" ref="view_utility_customer_search"/>
        <field name="help" type="html">
            <p>Manage utility customers. Search by customer number, national ID, or mobile.</p>
        </field>
    </record>

    <record id="menu_utility_customer" model="ir.ui.menu">
        <field name="name">Customers</field>
        <field name="parent_id">menu_utility_customer_mgmt</field>
        <field name="action" ref="action_utility_customer"/>
        <field name="sequence">10</field>
    </record>
</odoo>
