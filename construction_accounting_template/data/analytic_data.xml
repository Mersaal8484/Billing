        <!-- ==========
             COST CATEGORY PLAN (خطة تصنيف التكلفة - الطرف المتلقي)
             ==========
             Each cost category is an analytic account under this plan.
             Used as Axis 2 on every transaction.
             ========== -->

        <record id="analytic_plan_cost_category" model="account.analytic.plan">
            <field name="name">Cost Category - تصنيف التكلفة</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="analytic_account_materials" model="account.analytic.account">
            <field name="name">A1 - مواد (Materials)</field>
            <field name="plan_id" ref="analytic_plan_cost_category"/>
            <field name="active" eval="True"/>
        </record>
        <record id="analytic_account_subcontractors" model="account.analytic.account">
            <field name="name">A2 - مقاولو باطن (Subcontractors)</field>
            <field name="plan_id" ref="analytic_plan_cost_category"/>
            <field name="active" eval="True"/>
        </record>
