<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Fiscal Position: Local KSA (auto-apply for SA customers) -->
        <record id="fp_local_ksa" model="account.fiscal.position.template">
            <field name="name">محلي (داخل المملكة)</field>
            <field name="auto_apply" eval="True"/>
            <field name="sequence">10</field>
            <field name="country_id" ref="base.sa"/>
            <field name="chart_template_id" ref="construction_chart_template"/>
            <!-- No tax mappings needed: standard VAT 15% applies -->
        </record>

        <!-- Fiscal Position: GCC Export (صادرات دول الخليج) -->
        <record id="fp_gcc_export" model="account.fiscal.position.template">
            <field name="name">تصدير - دول الخليج (GCC)</field>
            <field name="auto_apply" eval="True"/>
            <field name="sequence">20</field>
            <field name="country_group_id" ref="base.gulf_cooperation_council"/>
            <field name="chart_template_id" ref="construction_chart_template"/>
            <!-- Map VAT 15% to VAT 0% for GCC exports -->
            <field name="tax_ids" eval="[
                (0, 0, {
                    'tax_src_id': ref('tax_sale_vat_15'),
                    'tax_dest_id': ref('tax_sale_vat_0'),
                }),
            ]"/>
        </record>

        <!-- Fiscal Position: Export Non-GCC (تصدير خارج الخليج) -->
        <record id="fp_export_non_gcc" model="account.fiscal.position.template">
            <field name="name">تصدير - خارج دول الخليج</field>
            <field name="auto_apply" eval="False"/>
            <field name="sequence">30</field>
            <field name="chart_template_id" ref="construction_chart_template"/>
            <field name="tax_ids" eval="[
                (0, 0, {
                    'tax_src_id': ref('tax_sale_vat_15'),
                    'tax_dest_id': ref('tax_sale_vat_0'),
                }),
            ]"/>
        </record>

        <!-- Fiscal Position: Reverse Charge (تحميل عكسي) -->
        <record id="fp_reverse_charge" model="account.fiscal.position.template">
            <field name="name">تحميل عكسي للضريبة (Reverse Charge)</field>
            <field name="auto_apply" eval="False"/>
            <field name="sequence">40</field>
            <field name="chart_template_id" ref="construction_chart_template"/>
            <field name="tax_ids" eval="[
                (0, 0, {
                    'tax_src_id': ref('tax_purchase_vat_15'),
                    'tax_dest_id': ref('tax_purchase_vat_0'),
                }),
            ]"/>
        </record>

    </data>
</odoo>
