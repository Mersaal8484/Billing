<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             VAT 15% - Sales Tax (ضريبة القيمة المضافة 15% - مبيعات)
             ============================================================ -->
        <record id="tax_sale_vat_15" model="account.tax.template">
            <field name="name">VAT 15% (مبيعات)</field>
            <field name="type_tax_use">sale</field>
            <field name="amount">15</field>
            <field name="amount_type">percent</field>
            <field name="description">VAT 15%</field>
            <field name="tax_group_id" ref="tax_group_vat"/>
            <field name="chart_template_id" ref="construction_chart_template"/>
            <field name="price_include" eval="False"/>
            <field name="invoice_repartition_line_ids" eval="[
                (5, 0, 0),
                (0, 0, {
                    'repartition_type': 'base',
                    'factor_percent': 100,
                }),
                (0, 0, {
                    'repartition_type': 'tax',
                    'account_id': ref('acc_vat_output'),
                    'factor_percent': 100,
                }),
            ]"/>
            <field name="refund_repartition_line_ids" eval="[
                (5, 0, 0),
                (0, 0, {
                    'repartition_type': 'base',
                    'factor_percent': 100,
                }),
                (0, 0, {
                    'repartition_type': 'tax',
                    'account_id': ref('acc_vat_output'),
                    'factor_percent': -100,
                }),
            ]"/>
        </record>

