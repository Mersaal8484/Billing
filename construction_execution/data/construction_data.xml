        <!-- Resource Types -->
        <record id="resource_type_material" model="construction.resource.type">
            <field name="name">Material</field>
            <field name="code">MAT</field>
            <field name="sequence">10</field>
        </record>
        <record id="resource_type_labor" model="construction.resource.type">
            <field name="name">Labor</field>
            <field name="code">LAB</field>
