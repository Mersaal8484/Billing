<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_form_inherit_construction" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.construction</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <field name="company_id" position="after">
                <field name="is_converted_to_construction" invisible="1"/>
                <field name="construction_project_id" readonly="1"
                    attrs="{'invisible': [('is_converted_to_construction', '=', False)]}"/>
            </field>
            <div class="oe_button_box" name="button_box" position="inside">
                <button name="action_create_construction_project" type="object"
                    class="oe_stat_button" icon="fa-building-o"
                    attrs="{'invisible': [('is_converted_to_construction', '=', True)]}">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Create Construction Project</span>
                    </div>
                </button>
            </div>
        </field>
    </record>
</odoo>
