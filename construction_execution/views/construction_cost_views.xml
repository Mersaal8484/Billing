<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cost Control Views -->
    <record id="view_construction_cost_control_tree" model="ir.ui.view">
        <field name="name">construction.cost.control.tree</field>
        <field name="model">construction.cost.control</field>
        <field name="arch" type="xml">
            <tree string="Cost Control" decoration-success="variance>=0" decoration-danger="variance&lt;0">
                <field name="project_id"/>
                <field name="boq_item_id"/>
                <field name="cost_code"/>
                <field name="budget_cost" widget="monetary" sum="Total"/>
                <field name="committed_cost" widget="monetary" sum="Total"/>
                <field name="actual_cost" widget="monetary" sum="Total"/>
                <field name="remaining_cost" widget="monetary" sum="Total"/>
                <field name="variance" widget="monetary" sum="Total"/>
                <field name="variance_percent"/>
                <field name="spi"/>
                <field name="cpi"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_cost_control_form" model="ir.ui.view">
        <field name="name">construction.cost.control.form</field>
        <field name="model">construction.cost.control</field>
        <field name="arch" type="xml">
            <form string="Cost Control">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="project_id"/> / <field name="boq_item_id"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="cost_code"/>
                            <field name="resource_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cost Summary">
                            <group>
                                <group>
                                    <field name="budget_cost" widget="monetary"/>
                                    <field name="committed_cost" widget="monetary"/>
                                    <field name="actual_cost" widget="monetary"/>
                                    <field name="forecast_cost" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="remaining_cost" widget="monetary"/>
                                    <field name="variance" widget="monetary"/>
                                    <field name="variance_percent" widget="percentage"/>
                                </group>
                            </group>
                        </page>
                        <page string="Earned Value">
                            <group>
                                <group>
                                    <field name="earned_value" widget="monetary"/>
                                    <field name="planned_value" widget="monetary"/>
                                    <field name="actual_cost_ev" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="schedule_variance" widget="monetary"/>
                                    <field name="cost_variance" widget="monetary"/>
                                    <field name="spi"/>
                                    <field name="cpi"/>
                                </group>
                            </group>
                            <group string="Forecast">
                                <field name="bac" widget="monetary"/>
                                <field name="eac" widget="monetary"/>
                                <field name="etc" widget="monetary"/>
                                <field name="vac" widget="monetary"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_construction_cost_control_search" model="ir.ui.view">
        <field name="name">construction.cost.control.search</field>
        <field name="model">construction.cost.control</field>
        <field name="arch" type="xml">
            <search string="Search Cost Control">
                <field name="project_id"/>
                <field name="boq_item_id"/>
                <field name="cost_code"/>
                <filter name="group_by_project" string="Project" context="{'group_by': 'project_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_construction_cost_control_pivot" model="ir.ui.view">
        <field name="name">construction.cost.control.pivot</field>
        <field name="model">construction.cost.control</field>
        <field name="arch" type="xml">
            <pivot string="Cost Analysis" disable_linking="1">
                <field name="budget_cost" type="measure"/>
                <field name="actual_cost" type="measure"/>
                <field name="variance" type="measure"/>
                <field name="spi" type="measure"/>
                <field name="cpi" type="measure"/>
                <field name="project_id" type="row"/>
                <field name="cost_code" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_construction_cost_control_graph" model="ir.ui.view">
        <field name="name">construction.cost.control.graph</field>
        <field name="model">construction.cost.control</field>
        <field name="arch" type="xml">
            <graph string="Cost Chart" type="bar">
                <field name="budget_cost" type="measure"/>
                <field name="actual_cost" type="measure"/>
                <field name="variance" type="measure"/>
                <field name="project_id" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_construction_cost_control" model="ir.actions.act_window">
        <field name="name">Cost Control</field>
        <field name="res_model">construction.cost.control</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_construction_cost_control_search"/>
    </record>

    <!-- Cost Entry Views -->
    <record id="view_construction_cost_entry_tree" model="ir.ui.view">
        <field name="name">construction.cost.entry.tree</field>
        <field name="model">construction.cost.entry</field>
        <field name="arch" type="xml">
            <tree string="Cost Entries">
                <field name="name"/>
                <field name="project_id"/>
                <field name="boq_item_id"/>
                <field name="cost_type" widget="badge"/>
                <field name="amount" widget="monetary" sum="Total"/>
                <field name="quantity"/>
                <field name="date"/>
                <field name="ref"/>
                <field name="account_move_id"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_cost_entry_form" model="ir.ui.view">
        <field name="name">construction.cost.entry.form</field>
        <field name="model">construction.cost.entry</field>
        <field name="arch" type="xml">
            <form string="Cost Entry">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="boq_item_id"/>
                            <field name="resource_id"/>
                            <field name="cost_type"/>
                            <field name="date"/>
                            <field name="ref"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary"/>
                            <field name="quantity"/>
                            <field name="unit_price" widget="monetary"/>
                            <field name="is_billable"/>
                            <field name="account_id"/>
                            <field name="analytic_account_id"/>
                        </group>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_construction_cost_entry_search" model="ir.ui.view">
        <field name="name">construction.cost.entry.search</field>
        <field name="model">construction.cost.entry</field>
        <field name="arch" type="xml">
            <search string="Search Cost Entries">
                <field name="name"/>
                <field name="project_id"/>
                <field name="boq_item_id"/>
                <field name="cost_type"/>
                <filter name="material" string="Material" domain="[('cost_type','=','material')]"/>
                <filter name="labor" string="Labor" domain="[('cost_type','=','labor')]"/>
                <filter name="equipment" string="Equipment" domain="[('cost_type','=','equipment')]"/>
                <filter name="subcontract" string="Subcontract" domain="[('cost_type','=','subcontract')]"/>
                <filter name="group_by_project" string="Project" context="{'group_by': 'project_id'}"/>
                <filter name="group_by_type" string="Type" context="{'group_by': 'cost_type'}"/>
            </search>
        </field>
    </record>

    <record id="view_construction_cost_entry_pivot" model="ir.ui.view">
        <field name="name">construction.cost.entry.pivot</field>
        <field name="model">construction.cost.entry</field>
        <field name="arch" type="xml">
            <pivot string="Cost Entry Analysis" disable_linking="1">
                <field name="amount" type="measure"/>
                <field name="project_id" type="row"/>
                <field name="cost_type" type="col"/>
                <field name="date" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="action_construction_cost_entry" model="ir.actions.act_window">
        <field name="name">Cost Entries</field>
        <field name="res_model">construction.cost.entry</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="search_view_id" ref="view_construction_cost_entry_search"/>
    </record>
</odoo>
