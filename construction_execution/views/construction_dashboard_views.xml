<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_construction_dashboard_pivot" model="ir.ui.view">
        <field name="name">construction.dashboard.pivot</field>
        <field name="model">construction.dashboard</field>
        <field name="arch" type="xml">
            <pivot string="Dashboard KPIs" disable_linking="1">
                <field name="project_value" type="measure"/>
                <field name="executed_value" type="measure"/>
                <field name="remaining_value" type="measure"/>
                <field name="budget_cost" type="measure"/>
                <field name="actual_cost" type="measure"/>
                <field name="cost_variance" type="measure"/>
                <field name="progress_percent" type="measure"/>
                <field name="spi" type="measure"/>
                <field name="cpi" type="measure"/>
                <field name="project_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_construction_dashboard_graph" model="ir.ui.view">
        <field name="name">construction.dashboard.graph</field>
        <field name="model">construction.dashboard</field>
        <field name="arch" type="xml">
            <graph string="Dashboard Chart" type="bar">
                <field name="project_value" type="measure"/>
                <field name="executed_value" type="measure"/>
                <field name="budget_cost" type="measure"/>
                <field name="actual_cost" type="measure"/>
                <field name="project_id" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_construction_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">construction.dashboard</field>
        <field name="view_mode">pivot,graph</field>
        <field name="context">{'search_default_group_by_project': 1}</field>
    </record>

    <record id="action_construction_main_dashboard" model="ir.actions.client">
        <field name="name">Construction Dashboard</field>
        <field name="tag">reload</field>
        <field name="target">main</field>
    </record>
</odoo>
