<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Material Plan Views -->
    <record id="view_construction_material_plan_tree" model="ir.ui.view">
        <field name="name">construction.material.plan.tree</field>
        <field name="model">construction.material.plan</field>
        <field name="arch" type="xml">
            <tree string="Material Plans" decoration-success="state=='completed'" decoration-warning="state=='delayed'" decoration-info="state=='in_progress'">
                <field name="name"/>
                <field name="boq_item_id"/>
                <field name="resource_id"/>
                <field name="product_id"/>
                <field name="planned_quantity" sum="Total"/>
                <field name="executed_quantity" sum="Total"/>
                <field name="remaining_quantity" sum="Total"/>
                <field name="planned_cost" sum="Total" widget="monetary"/>
                <field name="date"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_material_plan_form" model="ir.ui.view">
        <field name="name">construction.material.plan.form</field>
        <field name="model">construction.material.plan</field>
        <field name="arch" type="xml">
            <form string="Material Plan">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="boq_item_id"/>
                            <field name="resource_id"/>
                            <field name="product_id"/>
                            <field name="uom_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="planned_quantity"/>
                            <field name="executed_quantity"/>
                            <field name="remaining_quantity"/>
                            <field name="unit_cost" widget="monetary"/>
                            <field name="planned_cost" widget="monetary"/>
                            <field name="actual_cost" widget="monetary"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_construction_material_plan_search" model="ir.ui.view">
        <field name="name">construction.material.plan.search</field>
        <field name="model">construction.material.plan</field>
        <field name="arch" type="xml">
            <search string="Search Material Plans">
                <field name="name"/>
                <field name="boq_item_id"/>
                <field name="resource_id"/>
                <field name="product_id"/>
                <filter name="planned" string="Planned" domain="[('state','=','planned')]"/>
                <filter name="completed" string="Completed" domain="[('state','=','completed')]"/>
            </search>
        </field>
    </record>

    <record id="action_construction_material_plan" model="ir.actions.act_window">
        <field name="name">Material Plans</field>
        <field name="res_model">construction.material.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_construction_material_plan_search"/>
    </record>

    <!-- Material Request Views -->
    <record id="view_construction_material_request_tree" model="ir.ui.view">
        <field name="name">construction.material.request.tree</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <tree string="Material Requests" decoration-success="state=='received'" decoration-warning="state=='submitted'" decoration-danger="state=='cancelled'" decoration-info="state=='approved'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="required_date"/>
                <field name="requested_by"/>
                <field name="state" widget="badge"/>
                <field name="total_quantity" sum="Total"/>
                <field name="total_cost" sum="Total" widget="monetary"/>
                <field name="has_purchase_orders" widget="boolean_fa"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_material_request_form" model="ir.ui.view">
        <field name="name">construction.material.request.form</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <form string="Material Request">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,ordered,received" clickable="True"/>
                    <button type="object" name="action_submit" string="Submit" states="draft" class="btn-primary"/>
                    <button type="object" name="action_approve" string="Approve" states="submitted" class="btn-primary"/>
                    <button type="object" name="action_create_purchase_order" string="Create Purchase Order" states="approved" class="btn-primary"/>
                    <button type="object" name="action_receive" string="Mark Received" states="ordered" class="btn-success"/>
                    <button type="object" name="action_cancel" string="Cancel" states="draft,submitted,approved" class="btn-danger"/>
                    <button type="object" name="action_draft" string="Reset to Draft" states="cancelled" class="btn-default"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="date"/>
                            <field name="required_date"/>
                        </group>
                        <group>
                            <field name="requested_by"/>
                            <field name="approved_by"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items">
                            <field name="line_ids">
                                <tree string="Items" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="uom_id"/>
                                    <field name="quantity"/>
                                    <field name="received_quantity"/>
                                    <field name="remaining_quantity"/>
                                    <field name="unit_cost" widget="monetary"/>
                                    <field name="total_cost" widget="monetary"/>
                                    <field name="boq_item_id" optional="hide"/>
                                    <field name="material_plan_id" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_construction_material_request_search" model="ir.ui.view">
        <field name="name">construction.material.request.search</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <search string="Search Material Requests">
                <field name="name"/>
                <field name="project_id"/>
                <filter name="approve" string="Approved" domain="[('state','=','approved')]"/>
                <filter name="received" string="Received" domain="[('state','=','received')]"/>
                <filter name="group_by_project" string="Project" context="{'group_by': 'project_id'}"/>
                <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_construction_material_request" model="ir.actions.act_window">
        <field name="name">Material Requests</field>
        <field name="res_model">construction.material.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_construction_material_request_search"/>
    </record>

    <!-- Material Issue Views -->
    <record id="view_construction_material_issue_tree" model="ir.ui.view">
        <field name="name">construction.material.issue.tree</field>
        <field name="model">construction.material.issue</field>
        <field name="arch" type="xml">
            <tree string="Material Issues" decoration-success="state=='done'" decoration-danger="state=='cancelled'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="issued_by"/>
                <field name="location_id"/>
                <field name="state" widget="badge"/>
                <field name="total_quantity" sum="Total"/>
                <field name="total_cost" sum="Total" widget="monetary"/>
                <field name="picking_id"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_material_issue_form" model="ir.ui.view">
        <field name="name">construction.material.issue.form</field>
        <field name="model">construction.material.issue</field>
        <field name="arch" type="xml">
            <form string="Material Issue">
                <header>
                    <field name="state" widget="statusbar" clickable="True"/>
                    <button type="object" name="action_create_stock_picking" string="Create Stock Picking" states="draft" class="btn-primary"/>
                    <button type="object" name="action_done" string="Mark Done" states="confirmed" class="btn-success"/>
                    <button type="object" name="action_cancel" string="Cancel" states="draft,confirmed" class="btn-danger"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="date"/>
                            <field name="issued_by"/>
                        </group>
                        <group>
                            <field name="source_location_id"/>
                            <field name="location_id"/>
                            <field name="received_by"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <tree string="Items" editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="uom_id"/>
                            <field name="quantity"/>
                            <field name="unit_cost" widget="monetary"/>
                            <field name="total_cost" widget="monetary"/>
                            <field name="boq_item_id" optional="hide"/>
                        </tree>
                    </field>
                    <field name="note"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_construction_material_issue" model="ir.actions.act_window">
        <field name="name">Material Issues</field>
        <field name="res_model">construction.material.issue</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Material Return Views -->
    <record id="view_construction_material_return_tree" model="ir.ui.view">
        <field name="name">construction.material.return.tree</field>
        <field name="model">construction.material.return</field>
        <field name="arch" type="xml">
            <tree string="Material Returns">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="returned_by"/>
                <field name="state" widget="badge"/>
                <field name="total_quantity" sum="Total"/>
                <field name="reason"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_material_return_form" model="ir.ui.view">
        <field name="name">construction.material.return.form</field>
        <field name="model">construction.material.return</field>
        <field name="arch" type="xml">
            <form string="Material Return">
                <header>
                    <field name="state" widget="statusbar" clickable="True"/>
                    <button type="object" name="action_confirm" string="Confirm" states="draft" class="btn-primary"/>
                    <button type="object" name="action_create_stock_return_picking" string="Create Stock Return" states="confirmed" class="btn-primary"/>
                    <button type="object" name="action_done" string="Done" states="confirmed" class="btn-success"/>
                    <button type="object" name="action_cancel" string="Cancel" states="draft,confirmed" class="btn-danger"/>
                </header>
                <sheet>
                    <h1><field name="name" readonly="1"/></h1>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="date"/>
                            <field name="returned_by"/>
                        </group>
                        <group>
                            <field name="source_location_id"/>
                            <field name="destination_location_id"/>
                            <field name="picking_id"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <tree string="Items" editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id"/>
                            <field name="uom_id"/>
                            <field name="quantity"/>
                            <field name="condition"/>
                            <field name="reason"/>
                        </tree>
                    </field>
                    <field name="reason"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_construction_material_return" model="ir.actions.act_window">
        <field name="name">Material Returns</field>
        <field name="res_model">construction.material.return</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
