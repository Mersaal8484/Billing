<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_construction_boq" model="ir.actions.report">
        <field name="name">BOQ Report</field>
        <field name="model">construction.boq</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">construction_execution.report_construction_boq</field>
        <field name="report_file">construction_execution.report_construction_boq</field>
        <field name="binding_model_id" ref="model_construction_boq"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'BOQ Report - %s' % (object.name)</field>
    </record>

    <record id="action_report_construction_ipc" model="ir.actions.report">
        <field name="name">IPC Report</field>
        <field name="model">construction.ipc</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">construction_execution.report_construction_ipc</field>
        <field name="report_file">construction_execution.report_construction_ipc</field>
        <field name="binding_model_id" ref="model_construction_ipc"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'IPC - %s' % (object.name)</field>
    </record>

    <record id="action_report_construction_progress" model="ir.actions.report">
        <field name="name">Progress Report</field>
        <field name="model">construction.progress</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">construction_execution.report_construction_progress</field>
        <field name="report_file">construction_execution.report_construction_progress</field>
        <field name="binding_model_id" ref="model_construction_progress"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Progress - %s' % (object.name)</field>
    </record>

    <!-- XLSX Reports -->
    <record id="action_report_construction_boq_xlsx" model="ir.actions.report">
        <field name="name">BOQ Report (XLSX)</field>
        <field name="model">construction.boq</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">construction_execution.report_construction_boq_xlsx</field>
        <field name="binding_model_id" ref="model_construction_boq"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
