<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Categories -->
    <record id="module_category_construction" model="ir.module.category">
        <field name="name">Construction</field>
        <field name="description">Construction Management</field>
        <field name="sequence">10</field>
    </record>

    <!-- Security Groups -->
    <record id="group_construction_auditor" model="res.groups">
        <field name="name">Read Only Auditor</field>
        <field name="category_id" ref="module_category_construction"/>
    </record>

    <record id="group_construction_finance" model="res.groups">
        <field name="name">Finance</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_auditor'))]"/>
    </record>

    <record id="group_construction_store_keeper" model="res.groups">
        <field name="name">Store Keeper</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_finance'))]"/>
    </record>

    <record id="group_construction_procurement" model="res.groups">
        <field name="name">Procurement Officer</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_store_keeper'))]"/>
    </record>

    <record id="group_construction_cost_controller" model="res.groups">
        <field name="name">Cost Controller</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_procurement'))]"/>
    </record>

    <record id="group_construction_site_engineer" model="res.groups">
        <field name="name">Site Engineer</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_cost_controller'))]"/>
    </record>

    <record id="group_construction_qs" model="res.groups">
        <field name="name">Quantity Surveyor</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_site_engineer'))]"/>
    </record>

    <record id="group_construction_engineer" model="res.groups">
        <field name="name">Planning Engineer</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_qs'))]"/>
    </record>

    <record id="group_construction_manager" model="res.groups">
        <field name="name">Project Manager</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_engineer'))]"/>
    </record>

    <record id="group_construction_director" model="res.groups">
        <field name="name">Project Director</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_manager'))]"/>
    </record>

    <record id="group_construction_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_director'))]"/>
    </record>

    <!-- Add to System Administrator -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_construction_admin'))]"/>
    </record>
</odoo>
