<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_property_property" model="ir.sequence">
            <field name="name">Property</field>
            <field name="code">property.property</field>
            <field name="prefix">PR-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_property_building" model="ir.sequence">
            <field name="name">Building</field>
            <field name="code">property.building</field>
            <field name="prefix">BLD-</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_property_floor" model="ir.sequence">
            <field name="name">Floor</field>
            <field name="code">property.floor</field>
            <field name="prefix">FL-</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_property_unit" model="ir.sequence">
            <field name="name">Unit</field>
            <field name="code">property.unit</field>
            <field name="prefix">UNT-</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_property_lease" model="ir.sequence">
            <field name="name">Lease Contract</field>
            <field name="code">property.lease</field>
            <field name="prefix">LSE-</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_property_payment" model="ir.sequence">
            <field name="name">Payment</field>
            <field name="code">property.payment</field>
            <field name="prefix">PAY-</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_property_deposit" model="ir.sequence">
            <field name="name">Security Deposit</field>
            <field name="code">property.deposit</field>
            <field name="prefix">DEP-</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_property_maintenance" model="ir.sequence">
            <field name="name">Maintenance Request</field>
            <field name="code">property.maintenance</field>
            <field name="prefix">MNT-</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_property_inspection" model="ir.sequence">
            <field name="name">Inspection</field>
            <field name="code">property.inspection</field>
            <field name="prefix">INS-</field>
            <field name="padding">5</field>
        </record>
    </data>
</odoo>
