<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_property_split_billing_wizard_form" model="ir.ui.view">
        <field name="name">property.split.billing.wizard.form</field>
        <field name="model">property.split.billing.wizard</field>
        <field name="arch" type="xml">
            <form string="Split Billing / CAM">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Shared Utility / CAM Expense"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="property_id"/>
                            <field name="service_type"/>
                            <field name="journal_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="total_amount" widget="monetary"/>
                            <field name="split_method"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional details or breakdown instructions..."/>
                </sheet>
                <footer>
                    <button name="action_generate_bills" string="Generate Service Charges" type="object" class="btn-primary" icon="fa-cogs"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_property_split_billing_wizard" model="ir.actions.act_window">
        <field name="name">Split Billing / CAM</field>
        <field name="res_model">property.split.billing.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
