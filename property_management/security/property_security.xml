<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_property" model="ir.module.category">
        <field name="name">Real Estate</field>
        <field name="description">Property &amp; Real Estate Management</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_property_auditor" model="res.groups">
        <field name="name">Read-Only Auditor</field>
        <field name="category_id" ref="module_category_property"/>
    </record>

    <record id="group_property_reception" model="res.groups">
        <field name="name">Reception</field>
        <field name="category_id" ref="module_category_property"/>
        <field name="implied_ids" eval="[(4, ref('group_property_auditor'))]"/>
    </record>

    <record id="group_property_owner" model="res.groups">
        <field name="name">Owner</field>
        <field name="category_id" ref="module_category_property"/>
        <field name="implied_ids" eval="[(4, ref('group_property_reception'))]"/>
    </record>

    <record id="group_property_maintenance" model="res.groups">
        <field name="name">Maintenance Manager</field>
        <field name="category_id" ref="module_category_property"/>
        <field name="implied_ids" eval="[(4, ref('group_property_owner'))]"/>
    </record>

    <record id="group_property_accountant" model="res.groups">
        <field name="name">Accountant</field>
        <field name="category_id" ref="module_category_property"/>
        <field name="implied_ids" eval="[(4, ref('group_property_maintenance'))]"/>
    </record>

    <record id="group_property_manager" model="res.groups">
        <field name="name">Property Manager</field>
        <field name="category_id" ref="module_category_property"/>
        <field name="implied_ids" eval="[(4, ref('group_property_accountant'))]"/>
    </record>

    <record id="group_property_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_property"/>
        <field name="implied_ids" eval="[(4, ref('group_property_manager'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
