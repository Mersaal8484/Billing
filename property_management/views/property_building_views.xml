<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_property_building_tree" model="ir.ui.view">
        <field name="name">property.building.tree</field>
        <field name="model">property.building</field>
        <field name="arch" type="xml">
            <tree string="Buildings">
                <field name="code"/>
                <field name="name"/>
                <field name="property_id"/>
                <field name="total_floors"/>
                <field name="total_units"/>
                <field name="occupied_units"/>
                <field name="manager_id"/>
                <field name="year_built"/>
            </tree>
        </field>
    </record>

    <record id="view_property_building_form" model="ir.ui.view">
        <field name="name">property.building.form</field>
        <field name="model">property.building</field>
        <field name="arch" type="xml">
            <form string="Building">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="property_id"/>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="arabic_name"/>
                        </group>
                        <group>
                            <field name="total_floors"/>
                            <field name="total_units"/>
                            <field name="occupied_units"/>
                            <field name="manager_id"/>
                            <field name="year_built"/>
                            <field name="total_area"/>
                        </group>
                    </group>
                    <field name="description"/>
                    <field name="image" widget="image"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_property_building_search" model="ir.ui.view">
        <field name="name">property.building.search</field>
        <field name="model">property.building</field>
        <field name="arch" type="xml">
            <search string="Search Buildings">
                <field name="name"/>
                <field name="code"/>
                <field name="property_id"/>
                <filter name="group_by_property" string="Property" context="{'group_by': 'property_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_property_building" model="ir.actions.act_window">
        <field name="name">Buildings</field>
        <field name="res_model">property.building</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_property_building_search"/>
    </record>
</odoo>
