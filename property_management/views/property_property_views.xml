<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_property_property_tree" model="ir.ui.view">
        <field name="name">property.property.tree</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">
            <tree string="Properties" decoration-success="status_code == 'ACTIVE'" decoration-warning="status_code == 'CONSTRUCTION'" decoration-muted="not active">
                <field name="status_code" invisible="1"/>
                <field name="active" invisible="1"/>
                <field name="code"/>
                <field name="name"/>
                <field name="property_type"/>
                <field name="status"/>
                <field name="city"/>
                <field name="total_units"/>
                <field name="occupied_units"/>
                <field name="occupancy_rate" widget="progressbar"/>
                <field name="annual_rent_income" sum="Total" widget="monetary"/>
                <field name="owner_id"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_property_property_form" model="ir.ui.view">
        <field name="name">property.property.form</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_units" type="object" class="oe_stat_button" icon="fa-building">
                            <div class="o_stat_info">
                                <field name="total_units" class="o_stat_value"/>
                                <span class="o_stat_text">Units</span>
                            </div>
                        </button>
                        <button name="action_open_leases" type="object" class="oe_stat_button" icon="fa-file-text">
                            <div class="o_stat_info">
                                <field name="lease_count" class="o_stat_value"/>
                                <span class="o_stat_text">Leases</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-wrench" type="object" name="action_open_leases">
                            <div class="o_stat_info">
                                <field name="maintenance_count" class="o_stat_value"/>
                                <span class="o_stat_text">Maintenance</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                        <group>
                            <group>
                                <field name="name" placeholder="Property Name"/>
                                <field name="code"/>
                                <field name="property_type"/>
                                <field name="status"/>
                            </group>
                            <group>
                                <field name="owner_id"/>
                                <field name="manager_id"/>
                                <field name="partner_id"/>
                            </group>
                        </group>
                    </div>
                    <notebook>
                        <page string="Details">
                            <group string="Location">
                                <field name="address"/>
                                <field name="street"/>
                                <field name="street2"/>
                                <field name="city"/>
                                <field name="state_id"/>
                                <field name="zip"/>
                                <field name="country_id"/>
                                <field name="latitude"/>
                                <field name="longitude"/>
                                <field name="google_map_link" widget="url"/>
                            </group>
                            <group string="Financials">
                                <field name="purchase_date"/>
                                <field name="purchase_price" widget="monetary"/>
                                <field name="current_value" widget="monetary"/>
                                <field name="construction_date"/>
                                <field name="total_area"/>
                            </group>
                        </page>
                        <page string="Accounting">
                            <div class="oe_button_box" name="accounting_button_box">
                                <button name="action_create_custom_accounts" type="object" string="Generate Property Accounts" class="btn btn-secondary mb16" icon="fa-cogs" help="Generate custom accounts and journals specific to this property"/>
                            </div>
                            <group>
                                <group>
                                    <field name="rent_journal_id"/>
                                    <field name="deposit_journal_id"/>
                                    <field name="maintenance_journal_id"/>
                                    <field name="cash_journal_id"/>
                                    <field name="bank_journal_id"/>
                                </group>
                                <group>
                                    <field name="receivable_account_id"/>
                                    <field name="rent_income_account_id"/>
                                    <field name="service_income_account_id"/>
                                    <field name="deposit_liability_account_id"/>
                                    <field name="advance_liability_account_id"/>
                                    <field name="maintenance_expense_account_id"/>
                                    <field name="cash_account_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Performance">
                            <group string="Occupancy">
                                <field name="total_units"/>
                                <field name="occupied_units"/>
                                <field name="vacant_units"/>
                                <field name="occupancy_rate" widget="progressbar"/>
                            </group>
                            <group string="Financial Performance">
                                <field name="annual_rent_income" widget="monetary"/>
                                <field name="total_maintenance_cost" widget="monetary"/>
                                <field name="net_operating_income" widget="monetary"/>
                                <field name="property_value" widget="monetary"/>
                            </group>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                            <field name="arabic_name"/>
                        </page>
                        <page string="Notes">
                            <field name="note" widget="html"/>
                            <field name="internal_note"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_property_property_search" model="ir.ui.view">
        <field name="name">property.property.search</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">
            <search string="Search Properties">
                <field name="name"/>
                <field name="code"/>
                <field name="city"/>
                <field name="owner_id"/>
                <field name="manager_id"/>
                <filter name="active" string="Active" domain="[('status','=',1)]"/>
                <filter name="group_by_type" string="Type" context="{'group_by': 'property_type'}"/>
                <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
                <filter name="group_by_city" string="City" context="{'group_by': 'city'}"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_type_menu" string="Type" context="{'group_by': 'property_type'}"/>
                    <filter name="group_by_status_menu" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_property_property_pivot" model="ir.ui.view">
        <field name="name">property.property.pivot</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">
            <pivot string="Property Analysis" disable_linking="1">
                <field name="annual_rent_income" type="measure"/>
                <field name="occupancy_rate" type="measure"/>
                <field name="total_units" type="measure"/>
                <field name="total_maintenance_cost" type="measure"/>
                <field name="net_operating_income" type="measure"/>
                <field name="property_type" type="row"/>
                <field name="status" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="action_property_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">property.property</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="search_view_id" ref="view_property_property_search"/>
    </record>
</odoo>
